# Dependances
frontend/node_modules/
node_modules/
vendor/

# Builds
# NB : frontend/dist est VOLONTAIREMENT versionne (build de prod livre au
# serveur, qui n'a donc pas besoin de Node). Relancer `npm run build` apres
# toute modif du front, ou laisser deploy.sh reconstruire pour une autre cible.
build/

# Environnement / secrets locaux
.env
.env.local
*.local
# Fichiers d'env de l'API (contiennent des identifiants) ; seul .env.example
# est versionne. (frontend/.env.production ne contient qu'une URL -> versionne.)
api/.env
api/.env.development
api/.env.production

# Logs & temporaires
*.log
npm-debug.log*
*.tmp

# Outils / IDE
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Exports generes par l'API
api/rapports/
*.csv.tmp

# Config de prod avec identifiants en dur (ne pas committer)
deploy/config.prod.php
