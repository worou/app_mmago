# MamaGo API - front controller rewrite

# Ne JAMAIS servir les fichiers d'environnement (ils contiennent les
# identifiants de la base). Vaut aussi pour .env, .env.production, etc.
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

RewriteEngine On
RewriteBase /mamago/api/

# Certains Apache retirent l'entete Authorization : on la reinjecte pour PHP.
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Serve real files/directories directly (e.g. nothing here, but safe)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Fallback if mod_rewrite is disabled: PHP still resolves the path from REQUEST_URI
DirectoryIndex index.php
