# =====================================================================
# MamaGo API - modele de configuration d'environnement.
#
# Copier ce fichier en :
#   - api/.env.development  (dev local XAMPP)
#   - api/.env.production   (serveur ; NE PAS committer : contient un secret)
# ou en api/.env (fichier actif, prioritaire).
#
# Selection : la variable APP_ENV (defaut : development) determine le fichier
# .env.<APP_ENV> charge, sauf si un fichier api/.env existe (prioritaire).
# =====================================================================

APP_ENV=development

# --- Base de donnees ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mamago
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# --- API ---
# Prefixe d'URL de l'API : /mamago/api en dev XAMPP, /api en prod.
BASE_PATH=/mamago/api
# Origines CORS autorisees ('*' en dev ; restreindre en prod si besoin).
CORS_ALLOWED_ORIGINS=*
# Secret de signature des jetons (mettre une valeur aleatoire en prod).
JWT_SECRET=change-me
# Duree de validite d'un jeton, en secondes (8h).
JWT_TTL=28800
